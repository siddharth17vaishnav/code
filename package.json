{
  "name": "@code.siddharth/code",
  "version": "1.0.1",
  "description": "code — local RAG coding assistant powered by Ollama and LanceDB",
  "type": "module",
  "main": "./dist/cli/main.js",
  "bin": {
    "code": "./dist/cli/main.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "dev": "tsx src/cli/dev.ts",
    "chat": "tsx src/cli/chat.ts",
    "chat:simple": "tsx src/cli/chat.ts --simple",
    "chat:watch": "tsx src/cli/chat.ts --watch",
    "index": "tsx src/cli/indexer.ts",
    "index:full": "tsx src/cli/indexer.ts --full",
    "query": "tsx src/cli/query.ts",
    "watch": "tsx src/cli/watch.ts",
    "start": "node dist/cli/main.js"
  },
  "keywords": [
    "ai",
    "ollama",
    "rag",
    "lancedb",
    "coding-assistant",
    "local-llm",
    "vector-search"
  ],
  "author": "Siddharth Vaishnav",
  "license": "ISC",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/siddharth17vaishnav/code.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.31.0",
    "dotenv": "^17.4.2",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.5",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
